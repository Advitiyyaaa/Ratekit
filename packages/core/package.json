{
  "name": "ratekit",
  "version": "0.1.0",
  "description": "Framework-agnostic rate-limiting library with multiple algorithms and pluggable storage backends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx benchmarks/run.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "rate-limit",
    "rate-limiter",
    "throttle",
    "token-bucket",
    "leaky-bucket",
    "sliding-window",
    "fixed-window",
    "redis",
    "middleware",
    "nodejs"
  ],
  "author": {
    "name": "Advitiya Arya"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ratekit"
  },
  "homepage": "https://github.com/your-username/ratekit#readme",
  "bugs": {
    "url": "https://github.com/your-username/ratekit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "ioredis": "^5.6.1",
    "tinybench": "^4.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
